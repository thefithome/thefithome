---
import Layout from '../layouts/Layout.astro'
import { client } from '../lib/sanity'
import { renderPortableText } from '../lib/portableText'
import { urlFor } from '../lib/sanityImage'

const home = await client.fetch(`*[_type == "home"][0]`)
---

<Layout title="The Fit Home" faq={home.faq}>

  <!-- HERO (FULL WIDTH) -->
  <section 
    slot="fullwidth"
    class="hero"
    style={`--bg-image: url(${urlFor(home.heroImage).url()})`}
  >
    <div class="hero-content">
      <h1>{home.heroTitle}</h1>
      <div class="hero-text" set:html={renderPortableText(home.heroText)} />
    </div>
  </section>

  <!-- YA NO HAY <main> -->

  <!-- VALUE PROPS -->
  <section>
    <h2>{home.valuePropsTitle}</h2>
    <ul>
      {home.valueProps?.map(item => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <!-- INTRO + FACTORES -->
  <section>
    <h2>{home.introTitle}</h2>
    <div set:html={renderPortableText(home.introText)} />

    {home.factors?.map(factor => (
      <div>
        <h3>{factor.title}</h3>
        <div set:html={renderPortableText(factor.text)} />
      </div>
    ))}
  </section>

  <!-- CATEGORÍAS -->
  <section>
    <h2>{home.categoriesTitle}</h2>

    <div class="categories">
      {home.categories?.map(cat => (
        <a href={`/${cat.slug}`} class="category-card">
          <span class="icon">{cat.icon}</span>
          <h3>{cat.title}</h3>
          <p>{cat.description}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- ERRORES -->
  <section>
    <h2>{home.mistakesTitle}</h2>
    <ul>
      {home.mistakes?.map(item => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <!-- FAQ -->
  <section>
    <h3>{home.faqTitle}</h3>

    {home.faq?.map(item => (
      <details>
        <summary>{item.question}</summary>
        <div set:html={renderPortableText(item.answer)} />
      </details>
    ))}
  </section>

</Layout>